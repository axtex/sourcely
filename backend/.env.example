# OpenAI — platform.openai.com
OPENAI_API_KEY=your_openai_api_key

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# AWS — IAM user with S3 + Lambda access
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-west-2
AWS_S3_BUCKET=sourcely-axtex-bucket
AWS_PROFILE=sourcely
AWS_LAMBDA_FUNCTION=sourcely-processor

# Database — auto-set by docker-compose
DATABASE_URL=postgresql://sourcely:sourcely@localhost:5432/sourcely
